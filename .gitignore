!models/saved/best_model.pkl
!models/saved/feature_names.json
!models/saved/experiment_manifest.json
!models/saved/pakistan_demo.pkl
!models/saved/pakistan_demo_features.json
!models/saved/.gitkeep

# Data — small CSVs are tracked for reproducibility
# Only exclude large/sensitive data files
